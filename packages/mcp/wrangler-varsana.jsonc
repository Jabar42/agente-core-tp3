{
  "name": "varsana-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "API_BASE_URL": "https://varsana-co.iaforchange.workers.dev"
  },
  "durable_objects": {
    "bindings": [
      { "name": "VarsanaMCP", "class_name": "VarsanaMCP" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["VarsanaMcpAgent"] },
    { "tag": "v2", "deleted_classes": ["VarsanaMcpAgent"] },
    { "tag": "v3", "new_sqlite_classes": ["VarsanaMCP"] }
  ],
  "observability": { "enabled": true }
}
